frontend/dist/
frontend/build/
backend/build/
coverage/
.cache/
.parcel-cache/
.eslintcache
.turbo/
.next/

# Environment files
backend/.env*
frontend/.env*
!.env.example
!backend/.env.example
!backend/.env.staging.example
!backend/.env.production.example
!frontend/.env.example
!frontend/.env.staging.example
!frontend/.env.production.example

