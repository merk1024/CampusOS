PORT=5000
NODE_ENV=production
APP_ENV=staging

DB_CLIENT=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/campusos_staging
PGSSLMODE=
PGSSL_REJECT_UNAUTHORIZED=
PGSSL_ALLOW_SELF_SIGNED=

JWT_SECRET=replace_with_a_long_random_value
JWT_EXPIRE=7d

FRONTEND_URL=https://campusos-staging-frontend.onrender.com

SUPERADMIN_EMAIL=erbol.abdusatov@alatoo.edu.kg
SUPERADMIN_NAME=Erbol Abdusatov
SUPERADMIN_BOOTSTRAP_PASSWORD=
SEED_ADMIN_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_STUDENT_PASSWORD=
IMPORT_DEFAULT_PASSWORD=

MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
